<Window x:Class="PART2POE.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PART2POE"
        mc:Ignorable="d"
        Title="CyberGuard AI Interface" Height="500" Width="850"
        Background="#1E1E2E" WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#94E2D5"/>
            <Setter Property="Foreground" Value="#11111B"/>
            <Setter Property="FontFamily" Value="Segoe UI Semibold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.3*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Margin="0,0,15,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <ListView x:Name="chats" Grid.Row="0" Margin="0,0,0,10" Background="#181825" BorderThickness="1" BorderBrush="#313244"/>

            <Grid Grid.Row="1" x:Name="input_action_panel" Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="question" Grid.Column="0" Height="45" FontFamily="Segoe UI" FontSize="14" VerticalContentAlignment="Center" Background="#313244" Foreground="#CDD6F4" BorderThickness="1" BorderBrush="#45475A" Padding="10,0"/>

                <Button Grid.Column="1" Width="90" Height="45" Margin="10,0,0,0" Content="Send" Click="send"/>
            </Grid>
        </Grid>

        <Grid Grid.Column="1">

            <Grid x:Name="home_grid" Visibility="Visible" VerticalAlignment="Center">
                <StackPanel>
                    <Image Source="Logo1.jpg" 
                           Width="120" 
                           Height="120" 
                           HorizontalAlignment="Center" 
                           Margin="0,0,0,15"
                           Stretch="Uniform"/>

                    <TextBlock Text="CyberGuard AI" Foreground="#94E2D5" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    <TextBlock Text="Your digital companion for tracking roadmap tasks and evaluating situational risk maps." Foreground="#CDD6F4" FontSize="13" TextWrapping="Wrap" TextAlignment="Center" Margin="0,0,0,30"/>
                    <Button Content="Proceed to Chat" Width="200" Height="42" HorizontalAlignment="Center" Click="proceed"/>
                </StackPanel>
            </Grid>

            <Grid x:Name="username_grid" Visibility="Collapsed" VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="Enter Identity Profile" Foreground="#94E2D5" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                    <TextBox x:Name="usernames_input" Height="40" Width="240" Margin="0,0,0,15" Background="#313244" Foreground="#CDD6F4" BorderBrush="#45475A" FontSize="14" VerticalContentAlignment="Center" HorizontalAlignment="Center" Padding="10,0"/>
                    <Button Height="40" Width="240" Content="Submit Username" HorizontalAlignment="Center" Click="submit_name"/>
                </StackPanel>
            </Grid>

            <TabControl x:Name="chat_grid" Visibility="Collapsed" Background="#1E1E2E" BorderBrush="#313244">
                <TabControl.Resources>
                    <Style TargetType="TabItem">
                        <Setter Property="Background" Value="#313244"/>
                        <Setter Property="Foreground" Value="#CDD6F4"/>
                        <Setter Property="Padding" Value="10,6"/>
                    </Style>
                </TabControl.Resources>

                <TabItem Header="📋 Roadmap">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="Targeted Objectives" Foreground="#94E2D5" FontSize="13" FontWeight="Bold" Margin="0,0,0,8"/>

                        <ListBox x:Name="taskList" Grid.Row="1" Background="#181825" BorderBrush="#313244" Foreground="#CDD6F4" Margin="0,0,0,10"/>

                        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Resolve ✔" Width="85" Height="30" Margin="0,0,5,0" Click="CompleteTask_Click" Background="#A6E3A1"/>
                            <Button Content="Purge 🗑" Width="85" Height="30" Click="DeleteTask_Click" Background="#F38BA8"/>
                        </StackPanel>
                    </Grid>
                </TabItem>

                <TabItem Header="🎮 Mini-Game">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <DockPanel Grid.Row="0" Margin="0,0,0,8">
                            <TextBlock Text="Awareness Evaluation" Foreground="#94E2D5" FontSize="13" FontWeight="Bold"/>
                            <TextBlock x:Name="quiz_score_txt" Text="Score: 0" Foreground="#A6E3A1" FontSize="13" FontWeight="Bold" HorizontalAlignment="Right"/>
                        </DockPanel>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,5">
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock x:Name="quiz_question_txt" 
                                           Text="Test your situational knowledge maps! Click 'Start Quiz' to run active incident evaluation tracks." 
                                           TextWrapping="Wrap" 
                                           FontSize="14" 
                                           Foreground="#CDD6F4" 
                                           Margin="0,0,0,15" 
                                           TextAlignment="Center"
                                           LineHeight="20"/>
                                <ListBox x:Name="quiz_options_list" Visibility="Collapsed" Background="#181825" BorderThickness="1" BorderBrush="#313244" Foreground="#CDD6F4" Padding="6" Margin="5,0"/>
                            </StackPanel>
                        </ScrollViewer>

                        <Button x:Name="quiz_action_btn" Grid.Row="2" Content="Start Quiz" Height="38" Click="QuizAction_Click" Background="#94E2D5"/>
                    </Grid>
                </TabItem>

                <TabItem Header="📜 System Log">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="Operations Audit Trace" Foreground="#94E2D5" FontSize="13" FontWeight="Bold" Margin="0,0,0,8"/>
                        <ListBox x:Name="activity_log_view" Grid.Row="1" Background="#11111B" BorderBrush="#313244" Foreground="#A6E3A1" FontFamily="Consolas" FontSize="11"/>
                    </Grid>
                </TabItem>
            </TabControl>
        </Grid>
    </Grid>
</Window>